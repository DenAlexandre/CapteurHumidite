<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HumiditySensorApp.ViewModels"
             xmlns:converters="clr-namespace:HumiditySensorApp.Converters"
             x:Class="HumiditySensorApp.Views.ManagementPage"
             x:DataType="vm:ManagementViewModel"
             Title="Gestion">

    <ContentPage.Resources>
        <converters:InvertBoolConverter x:Key="InvertBool" />
    </ContentPage.Resources>

    <Grid>

        <!-- Waiting Overlay -->
        <VerticalStackLayout IsVisible="{Binding IsWaiting}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="16"
                             Padding="32">
            <ActivityIndicator IsRunning="{Binding IsWaiting}"
                               Color="#1976D2"
                               HeightRequest="50"
                               WidthRequest="50"
                               HorizontalOptions="Center" />
            <Label Text="{Binding WaitingMessage}"
                   FontSize="16"
                   TextColor="#757575"
                   HorizontalTextAlignment="Center" />
            <Button Text="Réessayer"
                    Command="{Binding LoadConfigCommand}"
                    BackgroundColor="#1976D2"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="40"
                    FontSize="14"
                    HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Main Content -->
        <ScrollView IsVisible="{Binding IsWaiting, Converter={StaticResource InvertBool}}">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Error Banner -->
                <Border BackgroundColor="#FFEBEE"
                        StrokeShape="RoundRectangle 8"
                        Stroke="#EF5350"
                        Padding="12"
                        IsVisible="{Binding HasError}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="#C62828"
                               FontSize="14" />
                        <Button Text="Réessayer"
                                Command="{Binding LoadConfigCommand}"
                                BackgroundColor="#EF5350"
                                TextColor="White"
                                HeightRequest="36"
                                CornerRadius="4"
                                FontSize="13" />
                    </VerticalStackLayout>
                </Border>

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="#1976D2"
                                   HeightRequest="40" />

                <!-- Setpoint Section -->
                <Border BackgroundColor="#F5F5F5"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Consigne d'humidité"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#333333" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <Slider Grid.Column="0"
                                    Minimum="10"
                                    Maximum="100"
                                    Value="{Binding Setpoint}"
                                    IsEnabled="{Binding IsServerAvailable}"
                                    MinimumTrackColor="#1976D2"
                                    MaximumTrackColor="#BBDEFB"
                                    ThumbColor="#1565C0" />
                            <Label Grid.Column="1"
                                   Text="{Binding Setpoint, StringFormat='{0} %'}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#1565C0"
                                   VerticalOptions="Center"
                                   WidthRequest="60"
                                   HorizontalTextAlignment="End" />
                        </Grid>
                        <Button Text="Valider"
                                Command="{Binding SaveSetpointCommand}"
                                BackgroundColor="#1976D2"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="44"
                                FontSize="16" />
                    </VerticalStackLayout>
                </Border>

                <!-- Manual Mode Section -->
                <Border BackgroundColor="#F5F5F5"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0"
                                   Text="Mode Manuel"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="#333333"
                                   VerticalOptions="Center" />
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding IsManualMode}"
                                    IsEnabled="{Binding IsServerAvailable}"
                                    OnColor="#1976D2"
                                    ThumbColor="#1565C0" />
                        </Grid>

                        <!-- Ventilation toggle — only visible in manual mode -->
                        <Grid ColumnDefinitions="*,Auto"
                              IsVisible="{Binding IsManualMode}">
                            <Label Grid.Column="0"
                                   Text="Ventilation"
                                   FontSize="16"
                                   TextColor="#555555"
                                   VerticalOptions="Center" />
                            <Switch Grid.Column="1"
                                    IsToggled="{Binding IsVentilationOn}"
                                    IsEnabled="{Binding IsServerAvailable}"
                                    OnColor="#4CAF50"
                                    ThumbColor="#388E3C" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Reboot Section -->
                <Border BackgroundColor="#FFEBEE"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Système"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#C62828" />
                        <Button Text="Redémarrer le Raspberry Pi"
                                Command="{Binding RebootCommand}"
                                BackgroundColor="#D32F2F"
                                TextColor="White"
                                CornerRadius="8"
                                HeightRequest="48"
                                FontSize="16" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
